# Supabase (public — bundled in client)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Optional: comma-separated extra hosts allowed for log location links & media (defaults to Supabase project host only)
# NEXT_PUBLIC_MEDIA_ALLOWED_HOSTS=cdn.example.com,images.example.com

# Server-only: HMAC secret for signed invite tokens (min 16 chars). Required for /api/invite/mint and /api/invite/verify.
INVITE_SIGNING_SECRET=change_me_to_a_long_random_string
